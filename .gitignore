# SymAD-ECNN .gitignore
# Excludes large data files, model checkpoints, and temporary files

# ========================================
# Python
# ========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/

# ========================================
# Jupyter Notebook
# ========================================
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# ========================================
# Data Files (TOO LARGE - USE GOOGLE DRIVE)
# ========================================
# BraTS dataset
data/brats2021/
data/brats2021_test/
*.nii
*.nii.gz

# IXI dataset
data/ixi/
data/processed_ixi/
data/resized_ixi/

# BraTS preprocessed data (LOCAL ONLY)
data/brats2021_processed/

# Preprocessed files
*.npy
*.npz

# Compressed data
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# HDF5 files
*.h5
*.hdf5

# ========================================
# Model Checkpoints (TOO LARGE)
# ========================================
# Trained models
models/saved_models/*.pth
models/saved_models/*.pt
models/*.pth
models/*.pt

# Keep directory structure but not files
!models/saved_models/.gitkeep
!models/.gitkeep

# ========================================
# Results & Outputs
# ========================================
# Large result files
results/*.pkl
results/*.pickle

# Keep sample results for documentation
!results/sample_*

# ========================================
# Logs & Temporary Files
# ========================================
*.log
*.tmp
*.temp
temp/
tmp/
logs/

# ========================================
# Operating System
# ========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ========================================
# IDEs & Editors
# ========================================
# VSCode
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml
*.iws
*.ipr

# Jupyter
.jupyter/

# Vim
*.swp
*.swo
*.swn
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# Sublime Text
*.sublime-project
*.sublime-workspace

# ========================================
# PDF Extraction Tool
# ========================================
pdfs/extract_pdf.py

# ========================================
# Project Specific
# ========================================
# Cached evaluation results
*.cache
cache/

# Visualization outputs (keep in results/)
# But exclude if too large
*.mp4
*.avi
*.gif

# ========================================
# Keep Important Files
# ========================================
# Force include certain files even if they match patterns above
!README.md
!LICENSE
!.gitignore
!requirements.txt
